algoritmo "Controle de Estoque"

var

    item: caractere  



inicio

    escreval("Digite o 1º item: ")
    leia(item)
    escreval(item, "registrado com sucesso")
    escreval("Escreva o segundo item: ")
    leia(item)
    escreval("item 1 descartado e item 2 registrado -->> " + item)
    item <- vazio


fimalgoritmo